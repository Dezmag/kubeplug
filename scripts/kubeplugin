#!/usr/bin/env bash

set -euo pipefail

RESOURCE_TYPE="${1:-}"
NAMESPACE="${2:-default}"

if [[ -z "$RESOURCE_TYPE" ]]; then
  echo "Usage: kubectl kubeplugin <resource> [namespace]"
  exit 1
fi

echo "Resource, Namespace, Name, CPU, Memory"

kubectl top "$RESOURCE_TYPE" -n "$NAMESPACE" --no-headers 2>/dev/null | while read -r line; do
  NAME=$(awk '{print $1}' <<< "$line")
  CPU=$(awk '{print $2}' <<< "$line")
  MEMORY=$(awk '{print $3}' <<< "$line")

  echo "$RESOURCE_TYPE, $NAMESPACE, $NAME, $CPU, $MEMORY"
done