#!/usr/bin/env bash

set -euo pipefail

# Usage:
# kubectl kubeplugin <resource> <namespace>

RESOURCE="${1:-pods}"
NAMESPACE="${2:-kube-system}"

echo "Resource, Namespace, Name, CPU, Memory"

kubectl top "$RESOURCE" -n "$NAMESPACE" --no-headers 2>/dev/null | \
while read -r name cpu memory; do
    echo "$RESOURCE, $NAMESPACE, $name, $cpu, $memory"
done